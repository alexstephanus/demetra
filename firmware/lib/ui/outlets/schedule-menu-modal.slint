import { Button } from "std-widgets.slint";
import { AppColors } from "@ui/colors.slint";

export component ScheduleMenuModal inherits Rectangle {
    in property <bool> show-modal: false;
    in property <int> selected-window-index: -1;

    callback edit-clicked();
    callback delete-clicked();
    callback close();

    visible: root.show-modal;
    width: 100%;
    height: 100%;
    background: #000000cc;

    TouchArea {
        clicked => {
            root.close();
        }
    }

    Rectangle {
        width: 280px;
        height: 180px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: AppColors.background-light;
        border-radius: 8px;

        TouchArea {}

        VerticalLayout {
            padding: 20px;
            spacing: 15px;
            alignment: center;

            Text {
                text: "Run Window Options";
                font-size: 18px;
                font-weight: 700;
                color: AppColors.text-primary;
                horizontal-alignment: center;
            }

            Button {
                text: "Edit";
                height: 45px;
                clicked => {
                    root.edit-clicked();
                }
            }

            Button {
                text: "Delete";
                height: 45px;
                clicked => {
                    root.delete-clicked();
                }
            }
        }
    }
}
