import { AppUiState } from "@ui/state/state.slint";

export component ClockBar inherits Rectangle {
    background: #f0f0f0;
    width: 100%;
    height: 24px;
    in property<string> current-time;

    Text {
        text: root.current-time;
        font-size: 12pt;
        color: black;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}