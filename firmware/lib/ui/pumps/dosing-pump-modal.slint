import { Button } from "std-widgets.slint";
import { DosingPumpUiState, AppUiState, UiTreatmentSolution } from "@ui/state/state.slint";
import { AlphabeticalKeypad } from "@ui/components/alphabetical_keypad.slint";
import { TreatmentSolutionModal } from "@ui/pumps/treatment-solution-modal.slint";
import { NumericKeypad } from "@ui/components/numeric_keypad.slint";
import { AppColors } from "@ui/colors.slint";
import { ManualDosingMode, DosingPump, PumpHelpers } from "@ui/state/enums.slint";

component ManualDosingModal inherits Rectangle {
    in-out property <bool> modal-visible: false;
    in property <DosingPump> pump: DosingPump.DoseOne;
    in property <string> pump-name: "";

    in-out property <ManualDosingMode> mode: ManualDosingMode.Select;
    in-out property <bool> keypad-visible: false;
    in-out property <float> input-value: 0.0;
    in-out property <bool> is-dosing: false;

    callback close();
    callback start-volumetric-dose(pump: DosingPump, volume-ml: float);
    callback start-manual-pump(pump: DosingPump);
    callback stop-dose(pump: DosingPump);

    visible: root.modal-visible;
    width: 100%;
    height: 100%;

    if !root.keypad-visible: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000080;

        TouchArea {
            clicked => {
                root.mode = ManualDosingMode.Select;
                root.is-dosing = false;
                root.input-value = 0.0;
                root.close();
            }
        }
    }

    if root.keypad-visible: NumericKeypad {
        width: 100%;
        height: 100%;
        prompt: "Enter volume (mL):";
        min-value: 0.1;
        max-value: 1000.0;

        submit(value) => {
            root.input-value = value;
            root.keypad-visible = false;
            root.start-volumetric-dose(root.pump, value);
        }

        cancel() => {
            root.keypad-visible = false;
            root.mode = ManualDosingMode.Select;
        }
    }

    if !root.keypad-visible && root.mode == ManualDosingMode.Select: Rectangle {
        width: min(260px, root.width - 70px);
        height: min(350px, root.height - 60px);
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;

        background: white;
        border-radius: 15px;
        border-width: 2px;
        border-color: #333333;
        drop-shadow-blur: 10px;
        drop-shadow-color: #00000040;

        TouchArea {
            clicked => { /* no-op */ }
        }

        VerticalLayout {
            padding: 20px;
            spacing: 15px;

            Text {
                text: "Manual Dosing\n" + root.pump-name;
                font-size: 16px;
                font-weight: 700;
                horizontal-alignment: center;
                color: #333333;
                wrap: word-wrap;
            }

            VerticalLayout {
                spacing: 12px;

                Button {
                    text: "Volumetric Dose";
                    height: 50px;
                    clicked => {
                        root.mode = ManualDosingMode.VolumetricDose;
                        root.keypad-visible = true;
                    }
                }

                Button {
                    text: "Manual Pump Control";
                    height: 50px;
                    clicked => {
                        root.mode = ManualDosingMode.ManualControl;
                    }
                }
            }

            Button {
                text: "Back";
                height: 45px;
                clicked => {
                    root.mode = ManualDosingMode.Select;
                    root.close();
                }
            }
        }
    }

    if !root.keypad-visible && root.mode == ManualDosingMode.ManualControl: Rectangle {
        width: min(260px, root.width - 70px);
        height: min(280px, root.height - 60px);
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;

        background: white;
        border-radius: 15px;
        border-width: 2px;
        border-color: #333333;
        drop-shadow-blur: 10px;
        drop-shadow-color: #00000040;

        TouchArea {
            clicked => { /* no-op */ }
        }

        VerticalLayout {
            padding: 20px;
            spacing: 20px;

            Text {
                text: "Manual Pump Control\n" + root.pump-name;
                font-size: 16px;
                font-weight: 700;
                horizontal-alignment: center;
                color: #333333;
                wrap: word-wrap;
            }

            Button {
                text: root.is-dosing ? "Stop Pump" : "Start Pump";
                height: 60px;
                clicked => {
                    if (root.is-dosing) {
                        root.stop-dose(root.pump);
                        root.is-dosing = false;
                    } else {
                        root.start-manual-pump(root.pump);
                        root.is-dosing = true;
                    }
                }
            }

            Button {
                text: "Done";
                height: 45px;
                clicked => {
                    if (root.is-dosing) {
                        root.stop-dose(root.pump);
                    }
                    root.is-dosing = false;
                    root.mode = ManualDosingMode.Select;
                    root.close();
                }
            }
        }
    }
}

export component DosingPumpModal inherits Rectangle {
    // Properties
    in-out property <bool> modal-visible: false;
    in property <DosingPump> pump: DosingPump.DoseOne;
    in property <DosingPumpUiState> pump-state;

    in-out property <bool> keyboard-visible: false;
    in-out property <bool> treatment-modal-visible: false;
    in-out property <bool> manual-dosing-visible: false;

    // Callbacks
    callback close();
    callback rename-pump(pump: DosingPump, new-name: string);
    callback configure-treatment(pump: DosingPump, solution: UiTreatmentSolution);
    callback toggle-enabled(pump: DosingPump);
    callback start-calibration(pump: DosingPump);
    callback start-volumetric-dose(pump: DosingPump, volume-ml: float);
    callback start-manual-pump(pump: DosingPump);
    callback stop-manual-dose(pump: DosingPump);

    // Modal overlay (covers entire screen when visible)  
    visible: root.modal-visible;

    if !root.keyboard-visible && !root.treatment-modal-visible && !root.manual-dosing-visible: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000080;

        TouchArea {
            clicked => { root.close(); }
        }
    }

    // Show keyboard if it's visible
    if root.keyboard-visible: AlphabeticalKeypad {
        width: 100%;
        height: 100%;
        prompt: "Enter Dosing Pump Name"; 
        max-length: 15;

        submit(name) => {
            root.rename-pump(root.pump, name);
            root.keyboard-visible = false;
        }
        cancel() => {
            root.keyboard-visible = false;
        }
    }

    // Show treatment solution modal if it's visible
    if root.treatment-modal-visible: TreatmentSolutionModal {
        modal-visible: root.treatment-modal-visible;
        pump-number: PumpHelpers.get-dosing-pump-display-number(root.pump);
        pump-name: root.pump-state.name;
        current-solution: root.pump-state.treatment-solution;

        close() => {
            root.treatment-modal-visible = false;
        }
        solution-configured(solution) => {
            root.configure-treatment(root.pump, solution);
            root.treatment-modal-visible = false;
        }
    }

    // Show manual dosing modal if it's visible
    if root.manual-dosing-visible: ManualDosingModal {
        modal-visible: root.manual-dosing-visible;
        pump: root.pump;
        pump-name: root.pump-state.name;

        close() => {
            root.manual-dosing-visible = false;
        }
        start-volumetric-dose(pump, volume-ml) => {
            root.start-volumetric-dose(pump, volume-ml);
        }
        start-manual-pump(pump) => {
            root.start-manual-pump(pump);
        }
        stop-dose(pump) => {
            root.stop-manual-dose(pump);
        }
    }

    // Centered modal content (only show if keyboard and treatment modal are not visible)
    if !root.keyboard-visible && !root.treatment-modal-visible && !root.manual-dosing-visible: modal-content := Rectangle {
        width: min(240px, root.width - 80px);
        height: min(420px, root.height - 40px);
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        
        background: white;
        border-radius: 15px;
        border-width: 2px;
        border-color: #333333;
        drop-shadow-blur: 10px;
        drop-shadow-color: #00000040;
        
        TouchArea {
            // Prevent clicks from propagating to background
            clicked => { /* no-op */ }
        }

        VerticalLayout {
            padding: 25px;
            spacing: 20px;
            
            Text {
                text: "Dosing Pump " + PumpHelpers.get-dosing-pump-display-number(root.pump);
                font-size: 18px;
                font-weight: 700;
                horizontal-alignment: center;
                color: #333333;
                wrap: word-wrap;
                height: 50px;
            }
            
            VerticalLayout {
                spacing: 12px;

                Button {
                    text: "Dose Manually";
                    height: 45px;
                    clicked => {
                        root.manual-dosing-visible = true;
                    }
                }

                Button {
                    text: root.pump-state.enabled ? "Disable" : "Enable";
                    height: 45px;
                    clicked => {
                        root.toggle-enabled(root.pump);
                    }
                }

                Button {
                    text: "Configure Treatment\nSolution";
                    height: 45px;
                    clicked => {
                        root.treatment-modal-visible = true;
                    }
                }

                Button {
                    text: "Rename Pump";
                    height: 45px;
                    clicked => {
                        AppUiState.keyboard-set-display-value(root.pump-state.name);
                        root.keyboard-visible = true;
                    }
                }

                Button {
                    text: "Calibrate";
                    height: 45px;
                    clicked => {
                        root.start-calibration(root.pump);
                    }
                }
            }
        }
    }
}