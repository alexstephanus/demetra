// Global color definitions for consistent UI theming

export global AppColors {
    // Status indicator colors (softer tones)
    in-out property <color> status-ok: #51cf66;      // Green for OK/enabled status
    in-out property <color> status-error: #ff6b6b;   // Red for error/problem status
    in-out property <color> status-warning: #ffd43b; // Yellow for warning/needs attention
    in-out property <color> status-disabled: #adb5bd; // Light gray for disabled/unconfigured
    
    // Background colors
    in-out property <color> background-light: #ffffff;
    in-out property <color> background-border: #cccccc;
    in-out property <color> button-background: #e9ecef;

    // Text colors
    in-out property <color> text-primary: #000000;
    in-out property <color> text-secondary: #666666;
    
    // Current value indicator
    in-out property <color> current-indicator: #2c2c2c;

    // Navigation colors
    in-out property <color> nav-active: #2196F3;
    in-out property <color> nav-active-text: #2196F3;
}