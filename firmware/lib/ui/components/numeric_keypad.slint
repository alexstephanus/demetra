
import { Button } from "std-widgets.slint";
import { AppUiState } from "@ui/state/state.slint";
component KeypadButton {
    in property <string> text;
    in property <color> background-color: white;
    in property <color> border-color: gray;
    in property <bool> enabled: true;
    
    callback clicked();
    
    Rectangle {
        background: enabled ? (touch_area.pressed ? #e0e0e0 : background_color) : #f5f5f5;
        border-color: root.border-color;
        border-radius: 3px;
        border-width: 2px;
        
        Text {
            text: root.text;
            font-size: 16px;
            color: enabled ? black : gray;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        
        touch_area := TouchArea {
            width: parent.width;
            height: parent.height; 
            enabled: root.enabled;
            clicked => { root.clicked(); }
        }
    }
}

export component NumericKeypad inherits Rectangle {
    in property <string> prompt: "Enter value:";
    in property <float> min-value: 0.0;
    in property <float> max-value: 0.0;

    in-out property <string> display-value: "";
    in-out property <string> error-message: "";

    callback append_digit(digit: string);
    callback backspace();

    callback submit(float);
    callback cancel();

    Rectangle {
        background: white;
        width: 100%;
        height: 100%;
        
    VerticalLayout {
        padding: 10px;
        spacing: 10px;
        
        // Prompt
        Rectangle {
            height: 25px;
            Text {
                color: black;
                text: prompt;
                font-size: 16px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
            
        // Display area
        Rectangle {
            background: white;
            border-color: gray;
            border-width: 2px;
            border-radius: 5px;
            height: 40px;
            
            Text {
                text: display_value == "" ? "0" : display_value;
                font-size: 20px;
                color: black;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
            
        // Error message area
        Rectangle {
            height: 15px;
            Text {
                text: error_message;
                color: red;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
            
        // Number pad - using GridLayout with equal column widths
        GridLayout {
            spacing: 5px;
            
            Row {
                KeypadButton { col: 0; preferred-width: 80px; text: "7"; clicked => { append_digit("7"); } }
                KeypadButton { col: 1; preferred-width: 80px; text: "8"; clicked => { append_digit("8"); } }
                KeypadButton { col: 2; preferred-width: 80px; text: "9"; clicked => { append_digit("9"); } }
            }
            
            Row {
                KeypadButton { col: 0; preferred-width: 80px; text: "4"; clicked => { append_digit("4"); } }
                KeypadButton { col: 1; preferred-width: 80px; text: "5"; clicked => { append_digit("5"); } }
                KeypadButton { col: 2; preferred-width: 80px; text: "6"; clicked => { append_digit("6"); } }
            }

            Row {
                KeypadButton { col: 0; preferred-width: 80px; text: "1"; clicked => { append_digit("1"); } }
                KeypadButton { col: 1; preferred-width: 80px; text: "2"; clicked => { append_digit("2"); } }
                KeypadButton { col: 2; preferred-width: 80px; text: "3"; clicked => { append_digit("3"); } }
            }

            Row {
                KeypadButton { col: 0; preferred-width: 80px; text: "."; clicked => { append_digit("."); } }
                KeypadButton { col: 1; preferred-width: 80px; text: "0"; clicked => { append_digit("0"); } }
                KeypadButton {
                    col: 2; preferred-width: 80px;
                    text: "⌫";
                    background-color: gray;
                    clicked => { backspace(); } 
                }
            }
        }
            
        // Action buttons - equal width
        HorizontalLayout {
            spacing: 10px;
            
            Button {
                text: "Cancel";
                height: 45px;
                preferred-width: 80px;
                clicked => {
                    cancel();
                }
            }
            
            Button {
                text: "OK";
                height: 45px;
                preferred-width: 80px;
                enabled: is_valid_input();
                clicked => {
                    if (is_valid_input()) {
                        submit(display_value.to-float());
                    }
                }
            }
        }
    }
    }
    
    function is_valid_input() -> bool {
        if (display-value == "" || display-value == ".") {
            return false;
        }

        return self.display-value.to-float() >= min_value
            && self.display-value.to-float() <= max_value
            && error_message == "";
    }

    append_digit(digit) => {
        root.display-value = AppUiState.keypad-append-digit(digit, root.display-value);
    }

    backspace() => {
        root.display-value = AppUiState.keypad-backspace(root.display-value);
    }

}
