import { Button } from "std-widgets.slint";
import { AppUiState } from "@ui/state/state.slint";
import { AppColors } from "@ui/colors.slint";

component InputKey inherits Button {
    in property <string> lowercase-char;
    in property <string> uppercase-char;
    in property <string> symbol-char;
    in property <int> keyboard-mode: 0;

    out property <string> display-character: {
        if (root.keyboard-mode == 1) { root.uppercase-char }
        else if (root.keyboard-mode == 2) { root.symbol-char }
        else { root.lowercase-char }
    };

    callback character-pressed(string);

    text: root.display-character;

    clicked => {
        root.character-pressed(root.display-character);
    }
}

export component AlphabeticalKeypad inherits Rectangle {
    in property <string> prompt: "Enter text:";
    in property <int> max-length: 20;

    in-out property <string> display-value: "";
    in-out property <int> keyboard-mode: 0;

    callback submit(string);
    callback cancel();
    callback append-character(string);
    callback backspace-character();

    append-character(character) => {
        self.display-value = AppUiState.keyboard-append-character(character, self.display-value);
    }

    backspace-character() => {
        self.display-value = AppUiState.keyboard-backspace(self.display-value);
    }

    width: 100%;
    height: 100%;
    background: white;

    property <string> mode-button-text: {
        if (root.keyboard-mode == 0) { "ABC" }
        else if (root.keyboard-mode == 1) { "123" }
        else { "abc" }
    };

    VerticalLayout {
        padding: 10px;
        spacing: 6px;

        Text {
            text: root.prompt;
            font-size: 18px;
            horizontal-alignment: center;
            color: #333333;
            vertical-stretch: 0;
        }

        Rectangle {
            height: 40px;
            vertical-stretch: 0;
            border-radius: 6px;
            border-width: 2px;
            border-color: #cccccc;
            background: #f8f8f8;

            Text {
                text: root.display-value;
                font-size: 16px;
                horizontal-alignment: center;
                vertical-alignment: center;
                color: #333333;
            }
        }

        VerticalLayout {
            spacing: 4px;
            vertical-stretch: 1;

            HorizontalLayout {
                spacing: 4px;
                InputKey { lowercase-char: "a"; uppercase-char: "A"; symbol-char: "1"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "b"; uppercase-char: "B"; symbol-char: "2"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "c"; uppercase-char: "C"; symbol-char: "3"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "d"; uppercase-char: "D"; symbol-char: "4"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "e"; uppercase-char: "E"; symbol-char: "5"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
            }

            HorizontalLayout {
                spacing: 4px;
                InputKey { lowercase-char: "f"; uppercase-char: "F"; symbol-char: "6"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "g"; uppercase-char: "G"; symbol-char: "7"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "h"; uppercase-char: "H"; symbol-char: "8"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "i"; uppercase-char: "I"; symbol-char: "9"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "j"; uppercase-char: "J"; symbol-char: "0"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
            }

            HorizontalLayout {
                spacing: 4px;
                InputKey { lowercase-char: "k"; uppercase-char: "K"; symbol-char: "!"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "l"; uppercase-char: "L"; symbol-char: "@"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "m"; uppercase-char: "M"; symbol-char: "#"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "n"; uppercase-char: "N"; symbol-char: "$"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "o"; uppercase-char: "O"; symbol-char: "%"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
            }

            HorizontalLayout {
                spacing: 4px;
                InputKey { lowercase-char: "p"; uppercase-char: "P"; symbol-char: "^"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "q"; uppercase-char: "Q"; symbol-char: "&"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "r"; uppercase-char: "R"; symbol-char: "*"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "s"; uppercase-char: "S"; symbol-char: "("; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "t"; uppercase-char: "T"; symbol-char: ")"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
            }

            HorizontalLayout {
                spacing: 4px;
                InputKey { lowercase-char: "u"; uppercase-char: "U"; symbol-char: "-"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "v"; uppercase-char: "V"; symbol-char: "_"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "w"; uppercase-char: "W"; symbol-char: "="; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "x"; uppercase-char: "X"; symbol-char: "+"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
                InputKey { lowercase-char: "y"; uppercase-char: "Y"; symbol-char: "["; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }
            }

            HorizontalLayout {
                spacing: 4px;
                InputKey { lowercase-char: "z"; uppercase-char: "Z"; symbol-char: "]"; keyboard-mode: root.keyboard-mode; horizontal-stretch: 1; character-pressed(char) => { root.append-character(char); } }

                Button {
                    text: "Space";
                    horizontal-stretch: 2;
                    clicked => {
                        root.append-character(" ");
                    }
                }

                Button {
                    text: "⌫";
                    horizontal-stretch: 2;
                    clicked => {
                        root.backspace-character();
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            vertical-stretch: 0;
            Button {
                text: root.mode-button-text;
                height: 40px;
                horizontal-stretch: 1;
                clicked => {
                    root.keyboard-mode = Math.mod(root.keyboard-mode + 1, 3);
                }
            }

            Rectangle { width: 15px; }

            Button {
                text: "Cancel";
                height: 40px;
                horizontal-stretch: 1;
                clicked => {
                    root.display-value = "";
                    root.cancel();
                }
            }
            Button {
                text: "OK";
                height: 40px;
                horizontal-stretch: 1;
                clicked => {
                    root.submit(root.display-value);
                    root.display-value = "";
                }
            }
        }
    }
}
